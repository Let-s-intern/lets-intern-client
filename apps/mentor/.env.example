# =====================================================================
# apps/mentor — Vite + React (멘토 마이페이지)
# =====================================================================
# 이 파일은 git에 포함되며 *키 형태와 의미*만 기록한다.
# 실제 값은 .env(gitignored)에 작성한다.
# Vite는 빌드 시 환경변수를 정적으로 인라인하므로, 변경 후 반드시 재빌드.
# =====================================================================


# ---------------------------------------------------------------------
# 백엔드 API 연결
# ---------------------------------------------------------------------

# REST API v1 베이스 URL (절대 URL, 버전 prefix 까지 포함).
# 예) https://api.<운영 도메인>/api/v1
VITE_SERVER_API=

# REST API v2 베이스 URL (절대 URL).
# 예) https://api.<운영 도메인>/api/v2
VITE_SERVER_API_V2=

# REST API v3 베이스 URL (절대 URL). 현재 BE 미배포 — 호출 시 500.
# 예) https://api.<운영 도메인>/api/v3
VITE_SERVER_API_V3=

# 백엔드 호스트 루트 (API 경로 prefix 없음). **OAuth 콜백·호스트 루트 전용**.
# 예) https://api.<운영 도메인>
VITE_API_BASE_PATH=


# ---------------------------------------------------------------------
# 환경 메타
# ---------------------------------------------------------------------

# 환경 식별자. 값: development | production
VITE_PROFILE=development

# 이 앱의 base URL. 절대 URL 생성·SSO 콜백 처리에 사용.
# dev) http://localhost:3002   prod) https://<멘토 운영 도메인>
VITE_BASE_URL=http://localhost:3002

# 메인 웹(랜딩/사용자) 사이트 URL. 사이드바 외부 이동 링크에 사용.
# dev) http://localhost:3000   prod) https://<운영 도메인>
VITE_WEB_URL=


# ---------------------------------------------------------------------
# 모니터링·알림
# ---------------------------------------------------------------------

# 클라이언트 에러 Slack incoming webhook.
VITE_ERROR_WEBHOOK_URL=


# ---------------------------------------------------------------------
# ZEP 라이브 피드백 스페이스
# ---------------------------------------------------------------------
# 멘토 라이브 피드백 "입장하기" 클릭 시 임베드되는 ZEP 스페이스 설정.
# 값이 비어 있으면 모달이 "설정 누락" 안내 화면으로 표시된다.

# ZEP 스페이스 진입 URL. 예) https://zep.us/play/VqJNq6
VITE_ZEP_SPACE_URL=

# ZEP 스페이스 입장 코드 (모달 헤더 안내용, 선택).
VITE_ZEP_ENTRY_CODE=

# ZEP 스페이스 표시 이름 (모달 헤더 라벨, 선택).
VITE_ZEP_SPACE_NAME=


# ---------------------------------------------------------------------
# Jitsi 라이브 피드백
# ---------------------------------------------------------------------
# 프론트가 매칭별(feedbackId)로 방 이름을 생성해 회의실을 즉시 만든다.
# 셀프호스팅 단일 서버를 사용한다.

# Jitsi 셀프호스팅 서버 베이스 URL. 끝에 슬래시 포함 권장.
# 예) https://jitsi-ayjsueey4v9euvyy9gsgmmtz.supabin.com/
VITE_JITSI_BASE_URL=

# Jitsi 폴백(셀프호스팅) 서버 베이스 URL.
# 예) https://jitsi-letscareer.supabin.com/
VITE_JITSI_FALLBACK_URL=

# 방 이름 해시 salt — apps/web과 반드시 동일 값. 32자 이상 random 권장.
# 다른 조직과 우연한 방 충돌을 막고 외부자 추측을 어렵게 하는 안전선.
VITE_JITSI_ROOM_SALT=

# (선택) 통합 QA dev mock — 양측 .env에 같은 값 박아 같은 방 진입 테스트
VITE_JITSI_USE_DEV_MOCK=false
VITE_JITSI_DEV_MOCK_FEEDBACK_ID=999999
#