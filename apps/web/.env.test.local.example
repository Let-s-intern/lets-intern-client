# =====================================================================
# apps/web — Playwright E2E 환경 변수 템플릿
# =====================================================================
# 이 파일은 git 에 포함되며 *키 형태와 의미*만 기록한다.
# 실제 값은 .env.test.local (gitignored) 에 작성한다.
#
# .env.test.local 이 존재하지 않거나 키 값이 비어 있으면,
# 로그인 의존 시나리오 (storageState 사용) 는 자동 skip 된다.
# 비로그인 시나리오는 환경 변수 없이도 동작한다.
# =====================================================================


# ---------------------------------------------------------------------
# 기본 타겟
# ---------------------------------------------------------------------

# E2E 가 실행될 base URL. 비워 두면 playwright.config.ts 의 기본값
# (http://localhost:3000) 사용.
# staging 예) https://staging.letscareer.co.kr
PLAYWRIGHT_BASE_URL=

# E2E_BASE_URL 은 PLAYWRIGHT_BASE_URL 의 별칭. 둘 중 하나만 채워도 됨.
E2E_BASE_URL=


# ---------------------------------------------------------------------
# 테스트 계정 (storageState 생성용)
# ---------------------------------------------------------------------
# globalSetup 이 이 계정으로 1회 로그인 → e2e/.auth/storageState.json 저장.
# 이후 storageState 사용 시나리오는 로그인 단계 없이 인증 상태 재사용.

E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PW=


# ---------------------------------------------------------------------
# SSO 회귀 테스트
# ---------------------------------------------------------------------
# 최근 SSO 해시 처리 회귀를 방지하기 위해, 운영/스테이징에서 발급한
# 1회용 SSO 해시를 변수로 주입할 수 있게 한다.
# 비워 두면 SSO 해시 시나리오는 skip.

E2E_SSO_TEST_HASH=


# ---------------------------------------------------------------------
# 스크린샷 캡처 제어
# ---------------------------------------------------------------------
# on / 1 / (미설정)  : 모든 단계 캡처 + 실패 시 99-실패시점.png (default)
# failure-only       : 단계별 snap 호출 skip, 실패 시점만 캡처
# off / 0 / false    : 모든 캡처 skip (디버그 시간 단축용)
E2E_CAPTURE=


# ---------------------------------------------------------------------
# login → purchase 시나리오 (login-to-purchase.authenticated.spec.ts)
# ---------------------------------------------------------------------
# staging 의 테스트 전용 챌린지 "E2E_TEST-login_to_purchase" 를 대상으로
# 로그인 → 챌린지 상세 → 결제 입력 → 결제 완료까지 종단 검증.
# 무료 옵션 챌린지를 가정하므로 실 결제 사고 위험 없음.
# E2E_TEST_CHALLENGE_ID 또는 E2E_TEST_CHALLENGE_PATH 둘 중 하나만 채워도 됨.
# 둘 다 비어 있으면 시나리오 skip.

# 챌린지 ID (가장 빠름. /program/challenge/{ID} 로 조립됨)
E2E_TEST_CHALLENGE_ID=

# 챌린지 path 또는 풀 URL 직접 지정.
# 예) /program/challenge/123
# 예) https://staging.letscareer.co.kr/program/challenge/123
E2E_TEST_CHALLENGE_PATH=

# (선택) 챌린지에 옵션이 여러 개일 때 무료 옵션 ID
# 비워 두면 "무료/0원" 텍스트 매칭으로 fallback
E2E_TEST_CHALLENGE_OPTION_ID=

# 결제 입력 폼에 채울 더미 주문자 정보 (운영 데이터 오염 방지용 봇 정보)
E2E_TEST_PURCHASER_NAME=E2E봇
E2E_TEST_PURCHASER_PHONE=01000000000
# 비워 두면 E2E_TEST_USER_EMAIL 로 fallback
E2E_TEST_PURCHASER_EMAIL=
