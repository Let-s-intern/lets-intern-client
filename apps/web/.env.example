# =====================================================================
# apps/web — Next.js
# =====================================================================
# 이 파일은 git에 포함되며 *키 형태와 의미*만 기록한다.
# 실제 값은 .env.local(gitignored)에 작성한다.
# 자세한 라우팅·배포 동작: .claude/docs/letscareer/pnpm전환 메모 폴더/
# =====================================================================


# ---------------------------------------------------------------------
# 백엔드 API 연결
# ---------------------------------------------------------------------

# REST API v1 베이스 URL (절대 URL, 버전 prefix 까지 포함).
# axios v1 인스턴스가 모든 요청에 prefix로 사용.
# 예) https://api.<운영 도메인>/api/v1
NEXT_PUBLIC_SERVER_API=

# REST API v2 베이스 URL (절대 URL).
# axios v2 인스턴스가 사용. env push2 이후 baseURL 합성 없이 그대로 사용.
# 예) https://api.<운영 도메인>/api/v2
NEXT_PUBLIC_SERVER_API_V2=

# REST API v3 베이스 URL (절대 URL). 현재 BE 미배포 — 호출 시 500.
# axios v3 인스턴스가 사용.
# 예) https://api.<운영 도메인>/api/v3
NEXT_PUBLIC_SERVER_API_V3=

# 백엔드 호스트 루트 (API 경로 prefix 없음). **OAuth 콜백·호스트 루트 전용**.
# 일반 axios 인스턴스에서는 사용 X (env push2 이후 의미 좁힘).
# 예) https://api.<운영 도메인>
NEXT_PUBLIC_API_BASE_PATH=


# ---------------------------------------------------------------------
# 도메인 라우팅 (admin/mentor 분리 배포)
# ---------------------------------------------------------------------
# 비워 두면 web의 자체 /admin·/mentor 라우트로 fallback.
# (분리 배포가 깨졌을 때 즉시 통합 모드로 회귀 가능한 안전장치)
# 자세한 동작: 03-domain-routing.md

# 어드민 앱 서브도메인. 예) https://<어드민 운영 도메인>
NEXT_PUBLIC_ADMIN_URL=

# 멘토 앱 서브도메인. 예) https://<멘토 운영 도메인>
NEXT_PUBLIC_MENTOR_URL=


# ---------------------------------------------------------------------
# 결제 (TossPayments)
# ---------------------------------------------------------------------

# 토스 클라이언트 키. 운영은 `live_` prefix, 테스트는 `test_` prefix.
# 결제 위젯 초기화 시 사용.
NEXT_PUBLIC_TOSS_CLIENT_KEY=


# ---------------------------------------------------------------------
# 모니터링·알림
# ---------------------------------------------------------------------

# Sentry DSN (클라이언트·서버 동일 DSN).
NEXT_PUBLIC_SENTRY_DSN=

# 클라이언트 에러를 Slack으로 보내는 incoming webhook.
NEXT_PUBLIC_ERROR_WEBHOOK_URL=


# ---------------------------------------------------------------------
# 환경 메타
# ---------------------------------------------------------------------

# 현재 환경 식별자. 코드 분기·로깅 라벨로 사용.
# 값: development | production
NEXT_PUBLIC_PROFILE=development

# 이 앱의 base URL. 절대 URL 생성(이메일 링크·내부 fallback 등)에 사용.
# dev) http://localhost:3000   prod) https://<운영 도메인>
BASE_URL=http://localhost:3000

# 정규 운영 도메인. metadataBase / canonical / og:url / JSON-LD url 의 단일 소스.
# BASE_URL 과 의미 분리:
#   - BASE_URL    : 빌드 호스트(Vercel preview 도메인 포함)
#   - SITE_URL    : 사용자에게 노출되는 정규 운영 도메인 (Google에 신호로 전달됨)
# 미지정 시 BASE_URL → http://localhost:3000 으로 fallback.
# prod) https://www.letscareer.co.kr
NEXT_PUBLIC_SITE_URL=

# 비-운영 환경에서 robots noindex 강제. NEXT_PUBLIC_PROFILE !== 'production' 또는
# NO_INDEX === 'true' 면 모든 페이지가 'noindex, nofollow'.
NO_INDEX=


# ---------------------------------------------------------------------
# ZEP 라이브 피드백 스페이스
# ---------------------------------------------------------------------
# 멘티 라이브 피드백 "입장하기" 클릭 시 임베드되는 ZEP 스페이스 설정.
# 값이 비어 있으면 모달이 "설정 누락" 안내 화면으로 표시된다.

# ZEP 스페이스 진입 URL. 예) https://zep.us/play/VqJNq6
NEXT_PUBLIC_ZEP_SPACE_URL=

# ZEP 스페이스 입장 코드 (모달 헤더 안내용, 선택).
NEXT_PUBLIC_ZEP_ENTRY_CODE=

# ZEP 스페이스 표시 이름 (모달 헤더 라벨, 선택).
NEXT_PUBLIC_ZEP_SPACE_NAME=


# ---------------------------------------------------------------------
# Jitsi 라이브 피드백
# ---------------------------------------------------------------------
# 프론트가 매칭별로 방 이름을 생성해 회의실을 즉시 만든다.
# 1차로 공식 서버를 사용하고, 사용자가 "다른 서버로 입장"을 누르면
# 셀프호스팅 서버로 전환한다.

# Jitsi 기본(공식) 서버 베이스 URL. 끝에 슬래시 포함 권장.
# 예) https://meet.jit.si/
NEXT_PUBLIC_JITSI_BASE_URL=

# Jitsi 폴백(셀프호스팅) 서버 베이스 URL.
# 예) https://jitsi-letscareer.supabin.com/
NEXT_PUBLIC_JITSI_FALLBACK_URL=

# 방 이름 해시 salt — 멘토/멘티/어드민 동일 값.
# 32자 이상 random 권장 (예: openssl rand -hex 32). 운영 salt는 절대 공개 X.
# 다른 조직과 우연한 방 충돌을 막고 외부자 추측을 어렵게 하는 안전선.
NEXT_PUBLIC_JITSI_ROOM_SALT=

# (선택) 통합 QA dev mock — 양측 .env에 같은 값 박아 같은 방 진입 테스트
NEXT_PUBLIC_JITSI_USE_DEV_MOCK=false
NEXT_PUBLIC_JITSI_DEV_MOCK_FEEDBACK_ID=999999
