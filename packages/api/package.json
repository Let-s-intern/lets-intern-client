{
  "name": "@letscareer/api",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./generated/schemas": "./src/generated/letsCareerAPI.schemas.ts",
    "./generated/*": "./src/generated/*/*.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "fetch:spec": "node ./scripts/fetch-spec.mjs",
    "generate": "orval --config ./orval.config.ts",
    "gen:api": "pnpm fetch:spec && pnpm generate"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "axios": ">=1"
  },
  "devDependencies": {
    "@letscareer/tsconfig": "workspace:*",
    "@tanstack/react-query": "^5.49.2",
    "@types/node": "^20.0.0",
    "axios": "^1.15.0",
    "orval": "^7.14.0",
    "typescript": "^5.9.3"
  }
}
