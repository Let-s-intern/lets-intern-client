{
  "name": "lets-intern-client",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.17",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@letscareer/web",
    "dev:admin": "turbo run dev --filter=@letscareer/admin",
    "dev:mentor": "turbo run dev --filter=@letscareer/mentor",
    "prod": "turbo run dev:prod --filter=@letscareer/web",
    "prod:build": "turbo run build:prod --filter=@letscareer/web",
    "prod:start": "turbo run start:prod --filter=@letscareer/web",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@letscareer/web",
    "build:admin": "turbo run build --filter=@letscareer/admin",
    "build:mentor": "turbo run build --filter=@letscareer/mentor",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint --filter=@letscareer/web",
    "lint:admin": "turbo run lint --filter=@letscareer/admin",
    "lint:mentor": "turbo run lint --filter=@letscareer/mentor",
    "format": "prettier --write \"apps/{web,admin,mentor}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"apps/{web,admin,mentor}/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:web": "prettier --write \"apps/web/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:admin": "prettier --write \"apps/admin/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:mentor": "prettier --write \"apps/mentor/**/*.{ts,tsx,js,jsx,json,md}\"",
    "check": "pnpm format:check && pnpm lint",
    "check:web": "prettier --check \"apps/web/**/*.{ts,tsx,js,jsx,json,md}\" && pnpm lint:web",
    "check:admin": "prettier --check \"apps/admin/**/*.{ts,tsx,js,jsx,json,md}\" && pnpm lint:admin",
    "check:mentor": "prettier --check \"apps/mentor/**/*.{ts,tsx,js,jsx,json,md}\" && pnpm lint:mentor",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "turbo run typecheck --filter=@letscareer/web",
    "typecheck:admin": "turbo run typecheck --filter=@letscareer/admin",
    "typecheck:mentor": "turbo run typecheck --filter=@letscareer/mentor",
    "test": "turbo run test",
    "test:web": "turbo run test --filter=@letscareer/web",
    "test:admin": "turbo run test --filter=@letscareer/admin",
    "test:mentor": "turbo run test --filter=@letscareer/mentor",
    "e2e": "turbo run e2e --filter=@letscareer/web",
    "e2e:web": "turbo run e2e --filter=@letscareer/web",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@letscareer/prettier-config": "workspace:*",
    "@types/node": "^20.14.9",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "tar-fs": "2.1.4",
    "path-to-regexp": "6.3.0",
    "undici": "5.29.0"
  }
}
